# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
pip-wheel-metadata/

# --- Environments ---
.venv/
venv/
env/
.env
.env.*
!.env.example

# --- uv ---
# Keep uv.lock in version control. Cache dirs are local-only.
.uv/
.uv-cache/

# --- Editors / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- ML / data artifacts ---
checkpoints/*
!checkpoints/.gitkeep
data/*
!data/.gitkeep
wandb/
mlruns/
outputs/
runs/
logs/
*.ckpt
*.pt
*.pth
*.safetensors
*.bin
*.h5
*.tfrecord
*.npy
*.npz

# --- Papers (large PDFs; check in About-PI.md instead) ---
papers/**/*.pdf

# --- Test / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
