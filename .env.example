# Copy to .env and fill in. .env is gitignored.

# HuggingFace (PaliGemma, Gemma 3, FAST tokenizer all live behind the HF Hub)
HF_TOKEN=

# Weights & Biases (optional — used by training scripts if installed)
WANDB_API_KEY=
WANDB_PROJECT=pi-stack
WANDB_ENTITY=

# Inference server (scripts/infer_server.py)
PI_INFER_HOST=0.0.0.0
PI_INFER_PORT=8765

# CUDA visibility (set explicitly when sharing a multi-GPU box)
# CUDA_VISIBLE_DEVICES=0
